<?xml version="1.0" encoding="UTF-8"?>
<!--
  Dev-only secret store. Copy this file to `Secrets.plist` and fill in your token
  only if you deliberately re-enable the bundled Oura fallback locally.

  `Secrets.plist` is gitignored and excluded from the generated Xcode project.
  Do NOT commit it. The preferred path is to paste the token in-app via Settings
  → Oura, which stores it in iOS Keychain.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>OURA_PAT</key>
    <string>paste-your-oura-personal-access-token-here</string>
</dict>
</plist>
